BOT_TOKEN=your-telegram-bot-token
OPENAI_API_KEY=your-openai-api-key

# GPT model for literary editing (quality matters)
EDITOR_MODEL=gpt-4o
# GPT model for cleaning, classification, timeline (speed + cost)
FAST_MODEL=gpt-4o-mini
# Whisper model
WHISPER_MODEL=whisper-1

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://memoir:memoir@localhost:5432/memoir_bot

# Free tier limits
FREE_MEMORIES_LIMIT=5
FREE_CHAPTERS_LIMIT=1
FREE_QUESTIONS_LIMIT=3

# Tribute payment integration
TRIBUTE_API_KEY=your-tribute-api-key
TRIBUTE_WEBHOOK_SECRET=your-tribute-webhook-secret
TRIBUTE_PRODUCT_LINK=https://t.me/tribute/app?startapp=pXXX
TRIBUTE_FAMILY_PRODUCT_LINK=https://t.me/tribute/app?startapp=pYYY

# Webhook server (for Tribute payment callbacks)
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# Mini App URL — базовый HTTPS-адрес приложения (тот же, что для вебхуков)
# Пример Render: https://memoir-bot-xxx.onrender.com (без /webhook/...)
# Mini App будет по /miniapp. Оставьте пустым, чтобы отключить.
MINI_APP_URL=

# Your Telegram ID (for /create_promo, /grant_premium admin commands)
ADMIN_TELEGRAM_ID=0

# Premium subscription duration (days)
PREMIUM_DAYS=90

# API auth (for mobile app)
JWT_SECRET=your-random-secret-at-least-32-chars
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
